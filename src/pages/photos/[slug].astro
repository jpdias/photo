---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { imageUrl } from '../../utils/images';
import photos from '../../data/photos.json';
import type { Photo } from '../../types';

export function getStaticPaths() {
  return photos.map((photo: Photo) => ({
    params: { slug: photo.slug },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const index = photos.findIndex((p: Photo) => p.slug === photo.slug);
const prev = index > 0 ? photos[index - 1] : null;
const next = index < photos.length - 1 ? photos[index + 1] : null;
const related = photos
  .filter((p: Photo) => p.slug !== photo.slug && p.category === photo.category)
  .slice(0, 3);
---

<Base title={photo.title} description={photo.description || `${photo.title} — ${photo.location?.name ?? ''}`} image={imageUrl(photo.fullsize)} url={`/photos/${photo.slug}`}>
  <Header />
  <main class="detail">
    <div class="back-bar">
      <a href="/photo/" class="back">← back</a>
      <span class="back-index">{index + 1} / {photos.length}</span>
    </div>

    <div class="image-container">
      <img src={imageUrl(photo.fullsize)} alt={photo.title} />
    </div>

    <div class="meta-panel">
      <h1>{photo.title}</h1>
      {photo.description && <p class="desc">{photo.description}</p>}
      <div class="info">
        {photo.location && (
          <div class="info-item">
            <span class="label">location</span>
            <span>{photo.location.name}</span>
          </div>
        )}
        {photo.country && (
          <div class="info-item">
            <span class="label">country</span>
            <span>{photo.country}</span>
          </div>
        )}
        {photo.location && (
          <div class="info-item">
            <span class="label">coordinates</span>
            <span>{photo.location.lat.toFixed(4)}, {photo.location.lng.toFixed(4)}</span>
          </div>
        )}
        <div class="info-item">
          <span class="label">date</span>
          <span>{photo.date}</span>
        </div>
        <div class="info-item">
          <span class="label">camera</span>
          <span>{photo.camera}</span>
        </div>
        <div class="info-item">
          <span class="label">category</span>
          <span>{photo.category}</span>
        </div>
        {photo.tags.length > 0 && (
          <div class="info-item">
            <span class="label">tags</span>
            <div class="tags">
              {photo.tags.map(tag => <span class="tag">#{tag}</span>)}
            </div>
          </div>
        )}
      </div>

      <div class="nav-links">
        {prev && <a href={`/photo/photos/${prev.slug}`} class="nav-btn">← {prev.title}</a>}
        {next && <a href={`/photo/photos/${next.slug}`} class="nav-btn">{next.title} →</a>}
      </div>
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>more in {photo.category}</h2>
        <div class="related-grid">
          {related.map((p: Photo) => (
            <a href={`/photo/photos/${p.slug}`} class="related-item">
              <img src={imageUrl(p.thumbnail)} alt={p.title} />
              <span>{p.title}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Base>

<style>
  .detail {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 3rem;
  }

  .back-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .back-index {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .image-container {
    margin-bottom: 1.5rem;
  }

  .image-container img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 3px;
  }

  .meta-panel {
    margin-bottom: 2.5rem;
  }

  .meta-panel h1 {
    font-size: 1.4rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
  }

  .desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .info-item {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
  }

  .label {
    color: var(--text-muted);
    min-width: 80px;
    flex-shrink: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .tag {
    color: var(--accent);
  }

  .nav-links {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .nav-btn {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
  .nav-btn:hover {
    background: var(--accent);
    color: var(--bg);
    border-radius: 3px;
    padding: 0 0.25rem;
  }

  .related {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .related h2 {
    font-size: 1rem;
    font-weight: 300;
    margin-bottom: 1rem;
  }

  .related h2::before {
    content: '#';
    color: var(--accent);
    margin-right: 6px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }

  .related-item {
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    background: var(--bg-card);
    border-radius: 3px;
    transition: transform 0.2s;
  }

  .related-item:hover {
    transform: translateY(-2px);
  }

  .related-item img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    display: block;
  }

  .related-item span {
    display: block;
    padding: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
</style>
