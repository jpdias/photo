---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import { imageUrl } from '../../utils/images';
import photos from '../../data/photos.json';
import type { Photo } from '../../types';

export function getStaticPaths() {
  return photos.map((photo: Photo) => ({
    params: { slug: photo.slug },
    props: { photo },
  }));
}

const { photo } = Astro.props;
const index = photos.findIndex((p: Photo) => p.slug === photo.slug);
const prev = index > 0 ? photos[index - 1] : null;
const next = index < photos.length - 1 ? photos[index + 1] : null;
const related = photos
  .filter((p: Photo) => p.slug !== photo.slug && p.category === photo.category)
  .slice(0, 3);
---

<Base title={photo.title} description={photo.description || `${photo.title} — ${photo.location?.name ?? ''}`} image={imageUrl(photo.fullsize)} url={`/photos/${photo.slug}`}>
  <Header />

  {prev && (
    <a href={`/photo/photos/${prev.slug}`} class="side-nav side-nav--prev" aria-label={`Previous: ${prev.title}`}>
      <span class="side-nav-arrow">←</span>
    </a>
  )}
  {next && (
    <a href={`/photo/photos/${next.slug}`} class="side-nav side-nav--next" aria-label={`Next: ${next.title}`}>
      <span class="side-nav-arrow">→</span>
    </a>
  )}

  <main class="detail">
    <div class="back-bar">
      <a href="/photo/" class="back">← back</a>
      <span class="back-index">{index + 1} / {photos.length}</span>
    </div>

    <div class="image-container">
      <img src={imageUrl(photo.fullsize)} alt={photo.title} />
    </div>

    <div class="meta-panel">
      <h1>{photo.title}</h1>
      {photo.description && <p class="desc">{photo.description}</p>}
      <div class="info">
        {photo.location && (
          <div class="info-item">
            <span class="label">location</span>
            <span>{photo.location.name}</span>
          </div>
        )}
        {photo.country && (
          <div class="info-item">
            <span class="label">country</span>
            <span>{photo.country}</span>
          </div>
        )}
        {photo.location && (
          <div class="info-item">
            <span class="label">coordinates</span>
            <span>{photo.location.lat.toFixed(4)}, {photo.location.lng.toFixed(4)}</span>
          </div>
        )}
        <div class="info-item">
          <span class="label">date</span>
          <span>{photo.date}</span>
        </div>
        <div class="info-item">
          <span class="label">camera</span>
          <span>{photo.camera}</span>
        </div>
        {photo.iso && (
          <div class="info-item">
            <span class="label">iso</span>
            <span>ISO {photo.iso}</span>
          </div>
        )}
        {photo.aperture && (
          <div class="info-item">
            <span class="label">aperture</span>
            <span>{photo.aperture}</span>
          </div>
        )}
        {photo.focalLength && (
          <div class="info-item">
            <span class="label">focal length</span>
            <span>{photo.focalLength}</span>
          </div>
        )}
        {photo.shutterSpeed && (
          <div class="info-item">
            <span class="label">shutter</span>
            <span>{photo.shutterSpeed}</span>
          </div>
        )}
        <div class="info-item">
          <span class="label">category</span>
          <span>{photo.category}</span>
        </div>
        {photo.tags.length > 0 && (
          <div class="info-item">
            <span class="label">tags</span>
            <div class="tags">
              {photo.tags.map(tag => <span class="tag">#{tag}</span>)}
            </div>
          </div>
        )}
      </div>

      <div class="nav-links">
        <a href={prev ? `/photo/photos/${prev.slug}` : undefined} class:list={["nav-btn", "nav-btn--prev", { "nav-btn--disabled": !prev }]}>
          <span class="nav-arrow">←</span>
          <span class="nav-text">
            <span class="nav-label">prev</span>
            <span class="nav-title">{prev?.title ?? '—'}</span>
          </span>
        </a>
        <a href={next ? `/photo/photos/${next.slug}` : undefined} class:list={["nav-btn", "nav-btn--next", { "nav-btn--disabled": !next }]}>
          <span class="nav-text">
            <span class="nav-label">next</span>
            <span class="nav-title">{next?.title ?? '—'}</span>
          </span>
          <span class="nav-arrow">→</span>
        </a>
      </div>
    </div>

    {related.length > 0 && (
      <section class="related">
        <h2>more in {photo.category}</h2>
        <div class="related-grid">
          {related.map((p: Photo) => (
            <a href={`/photo/photos/${p.slug}`} class="related-item">
              <img src={imageUrl(p.thumbnail)} alt={p.title} />
              <span>{p.title}</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </main>
</Base>

<script define:vars={{ prevSlug: prev?.slug ?? null, nextSlug: next?.slug ?? null }}>
  let touchStartX = 0;
  let touchStartY = 0;

  document.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
  }, { passive: true });

  document.addEventListener('touchend', (e) => {
    const dx = e.changedTouches[0].clientX - touchStartX;
    const dy = e.changedTouches[0].clientY - touchStartY;
    if (Math.abs(dx) > Math.abs(dy) && Math.abs(dx) > 50) {
      if (dx > 0 && prevSlug) {
        window.location.href = `/photo/photos/${prevSlug}`;
      } else if (dx < 0 && nextSlug) {
        window.location.href = `/photo/photos/${nextSlug}`;
      }
    }
  }, { passive: true });
</script>

<style>
  /* ---------- side arrows, outside the photo/content column ---------- */
  .side-nav {
    position: fixed;
    top: 50%;
    transform: translateY(-50%);
    z-index: 30;
    display: none; /* only shown once there's real space beside the content, see media query */
    align-items: center;
    justify-content: center;
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: var(--bg-card);
    border: 1px solid var(--border);
    color: var(--text-muted);
    transition: color 0.2s, border-color 0.2s, transform 0.2s;
  }

  .side-nav:hover {
    color: var(--accent);
    border-color: var(--accent);
    transform: translateY(-50%) scale(1.06);
  }

  .side-nav-arrow {
    font-size: 1.4rem;
    line-height: 1;
  }

  .side-nav--prev { left: 2rem; }
  .side-nav--next { right: 2rem; }

  /* Content column is max-width 1100px + 1.5rem padding each side.
     Only show side arrows once the viewport actually has clear room
     to the left/right of that column for them to sit in. */
  @media (min-width: 1300px) {
    .side-nav { display: flex; }
  }

  @media (min-width: 1600px) {
    .side-nav--prev { left: 4rem; }
    .side-nav--next { right: 4rem; }
  }

  /* ---------- page ---------- */
  .detail {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 3rem;
  }

  .back-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .back {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .back-index {
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .image-container {
    margin-bottom: 1.5rem;
  }

  .image-container img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 3px;
  }

  .meta-panel {
    margin-bottom: 2.5rem;
  }

  .meta-panel h1 {
    font-size: 1.4rem;
    font-weight: 300;
    margin-bottom: 0.5rem;
  }

  .desc {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 1rem;
    line-height: 1.6;
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }

  .info-item {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
  }

  .label {
    color: var(--text-muted);
    min-width: 80px;
    flex-shrink: 0;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .tag {
    color: var(--accent);
  }

  /* ---------- bottom prev/next, left/right aligned with fixed gutter ---------- */
  .nav-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: stretch;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
  }

  .nav-btn {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.5rem 0;
    color: var(--text-muted);
    min-width: 0; /* allow text truncation inside grid/flex */
    transition: color 0.2s;
  }

  .nav-btn--next {
    justify-content: flex-end;
    text-align: right;
  }

  .nav-btn--disabled {
    pointer-events: none;
    opacity: 0.3;
  }

  .nav-btn:hover:not(.nav-btn--disabled) {
    color: var(--accent);
  }

  .nav-arrow {
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .nav-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .nav-btn--next .nav-text {
    align-items: flex-end;
  }

  .nav-label {
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    opacity: 0.7;
  }

  .nav-title {
    font-size: 0.85rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  .related {
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }

  .related h2 {
    font-size: 1rem;
    font-weight: 300;
    margin-bottom: 1rem;
  }

  .related h2::before {
    content: '#';
    color: var(--accent);
    margin-right: 6px;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.5rem;
  }

  .related-item {
    text-decoration: none;
    color: inherit;
    overflow: hidden;
    background: var(--bg-card);
    border-radius: 3px;
    transition: transform 0.2s;
  }

  .related-item:hover {
    transform: translateY(-2px);
  }

  .related-item img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    display: block;
  }

  .related-item span {
    display: block;
    padding: 0.4rem;
    font-size: 0.75rem;
    color: var(--text-muted);
  }
</style>