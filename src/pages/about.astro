---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
---

<Base title="About" description="Photographer, explorer, visual storyteller.">
  <Header currentPage="about" />
  <main>
    <section class="about">
      <h1>about</h1>

      <div class="bio">
        <p>
          Based in Porto, Portugal. Engineer by day, photographer whenever I can get out.
          I shoot landscapes, urban — whatever catches my eye.
        </p>
        <p>Canon shooter since 2018 (EOS R7). Edited in Lightroom.</p>
      </div>

      <section class="section">
        <h2>gear</h2>
        <div class="gear-grid">
          <div class="gear-item">
            <span class="gear-label">camera</span>
            <span class="gear-value">Canon EOS R7</span>
          </div>
          <div class="gear-item">
            <span class="gear-label">lens</span>
            <span class="gear-value">RF-S 18-150mm f/3.5-6.3</span>
          </div>
          <div class="gear-item">
            <span class="gear-label">lens</span>
            <span class="gear-value">RF 24mm f/1.8</span>
          </div>
          <div class="gear-item">
            <span class="gear-label">lens</span>
            <span class="gear-value">EF-S 55-250mm f/4-5.6</span>
          </div>
          <div class="gear-item">
            <span class="gear-label">lens</span>
            <span class="gear-value">EF 50mm f/1.8</span>
          </div>
          <div class="gear-item">
            <span class="gear-label">edit</span>
            <span class="gear-value">Lightroom</span>
          </div>
        </div>
      </section>

      <section class="section">
        <h2>achievements</h2>
        <ul class="list">
          <li>
            <span class="list-year">2025</span>
            <span>2nd place — <em>Photography Contest — U.Porto Alumni around the World</em>, by University of Porto</span>
          </li>
          <li>
            <span class="list-year">2024</span>
            <span>Winner — <em>2nd Photography Contest — Earth Week at FEUP</em>, by Faculty of Engineering, University of Porto</span>
          </li>
          <li>
            <span class="list-year">2020</span>
            <span>Winner — <em>Landscapes from Above</em> quest, by 500px</span>
          </li>
          <li>
            <span class="list-year">2019</span>
            <span>One of the 50 best pictures — <em>#MySocialEurope</em> photo competition, by the European Commission</span>
          </li>
          <li>
            <span class="list-year">2018</span>
            <span>Finalist — <em>Norte Multimédia Contest</em>, Photography Category, promoted by CCDR-N; exhibited at Trindade Metro Station, Porto</span>
          </li>
          <li>
            <span class="list-year">2018</span>
            <span>Finalist — <em>PORTUGAL NUM ISQUEIRO BIC Contest</em>, by BIC Portugal</span>
          </li>
          <li>
            <span class="list-year">2010</span>
            <span>Exposition — <em>Movimento d'Artes</em>, Cooperativa Cultural Vinha das Artes</span>
          </li>
        </ul>
      </section>

      <section class="section">
        <h2>contact</h2>
        <div class="contact-links">
          <a href="mailto:jpdias@pm.me">jpdias@pm.me</a>
          <a href="https://github.com/jpdias" target="_blank" rel="noopener">github</a>
        </div>
      </section>
    </section>
  </main>
</Base>

<style>
  .about {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  h1 {
    font-size: 1.65rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 2rem;
  }

  h1::before {
    content: '#';
    color: var(--accent);
    margin-right: 8px;
  }

  .bio {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .bio p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .section {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  h2::before {
    content: '#';
    color: var(--accent);
    margin-right: 6px;
  }

  .gear-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.5rem;
  }

  .gear-item {
    display: flex;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    background: var(--bg-card);
    border-radius: 3px;
    font-size: 0.8rem;
  }

  .gear-label {
    color: var(--text-muted);
    min-width: 50px;
    flex-shrink: 0;
  }

  .gear-value {
    color: var(--text);
  }

  .list {
    list-style: none;
    padding: 0;
  }

  .list li {
    display: flex;
    gap: 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .list li:last-child {
    border-bottom: none;
  }

  .list-year {
    color: var(--accent);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    min-width: 40px;
    flex-shrink: 0;
  }

  .list em {
    color: var(--text);
    font-style: normal;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contact-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    transition: color 0.15s, border-color 0.15s;
  }

  .contact-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: transparent;
  }
</style>
