---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import about from '../data/about.json';
import photos from '../data/photos.json';
import { imageUrl } from '../utils/images';

const photosBySlug = new Map(photos.map(p => [p.slug, p]));
---

<Base title="About" description="Photographer, explorer, visual storyteller.">
  <Header currentPage="about" />
  <main>
    <section class="about">
      <h1>about</h1>

      <div class="bio">
        {about.bio.map(line => <p>{line}</p>)}
      </div>

      <section class="section">
        <h2>gear</h2>
        <div class="gear-grid">
          {about.gear.map(item => (
            <div class="gear-item">
              <span class="gear-label">{item.label}</span>
              <span class="gear-value">{item.value}</span>
            </div>
          ))}
        </div>
      </section>

      <section class="section">
        <h2>achievements</h2>
        <ul class="list">
          {about.achievements.map(a => {
            const slugs = a.photoSlugs?.filter(Boolean) ?? [];
            return (
              <li>
                <span class="list-year">{a.year}</span>
                {slugs.length > 0 ? (
                  <details class="ach-details">
                    <summary class="ach-summary">
                      <span>
                        {a.result} — <em>{a.title}</em>
                        {a.organization && <span>, {a.organization}</span>}
                        {a.note && <span> — {a.note}</span>}
                      </span>
                      <span class="ach-arrow">↓</span>
                    </summary>
                    <div class="ach-thumbs">
                      {slugs.map(slug => {
                        const p = photosBySlug.get(slug);
                        if (!p) return null;
                        return (
                            <a href={`/photo/?slug=${slug}`} class="ach-thumb-link">
                            <img
                              class="ach-thumb"
                              src={imageUrl(p.thumbnail)}
                              alt={p.title}
                                width={160}
                                height={120}
                            />
                          </a>
                        );
                      })}
                    </div>
                  </details>
                ) : (
                  <span>
                    {a.result} — <em>{a.title}</em>
                    {a.organization && <span>, {a.organization}</span>}
                    {a.note && <span> — {a.note}</span>}
                  </span>
                )}
              </li>
            );
          })}
        </ul>
      </section>

      <section class="section">
        <h2>contact</h2>
        <div class="contact-links">
          <a href={`mailto:${about.contact.email}`}>{about.contact.email}</a>
          <a href={`https://github.com/${about.contact.github}`} target="_blank" rel="noopener">github</a>
        </div>
      </section>
    </section>
  </main>
</Base>

<style>
  .about {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  h1 {
    font-size: 1.65rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 2rem;
  }

  h1::before {
    content: '#';
    color: var(--accent);
    margin-right: 8px;
  }

  .bio {
    max-width: 640px;
    margin-bottom: 3rem;
  }

  .bio p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .section {
    margin-bottom: 3rem;
  }

  h2 {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border);
  }

  h2::before {
    content: '##';
    color: var(--accent);
    margin-right: 6px;
  }

  .gear-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.5rem;
  }

  .gear-item {
    display: flex;
    gap: 1rem;
    padding: 0.6rem 0.75rem;
    background: var(--bg-card);
    border-radius: 3px;
    font-size: 0.8rem;
  }

  .gear-label {
    color: var(--text-muted);
    min-width: 50px;
    flex-shrink: 0;
  }

  .gear-value {
    color: var(--text);
  }

  .list {
    list-style: none;
    padding: 0;
  }

  .list li {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .list li:last-child {
    border-bottom: none;
  }

  .list-year {
    color: var(--accent);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    min-width: 40px;
    flex-shrink: 0;
  }

  .list em {
    color: var(--text);
    font-style: normal;
  }

  .ach-details {
    flex: 1;
  }

  .ach-summary {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    cursor: pointer;
    list-style: none;
  }

  .ach-summary::-webkit-details-marker {
    display: none;
  }

  .ach-arrow {
    color: var(--accent);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.8rem;
    transition: transform 0.15s;
    flex-shrink: 0;
  }

  .ach-details[open] .ach-arrow {
    transform: rotate(180deg);
  }

  .ach-thumbs {
    display: flex;
    gap: 4px;
    margin-top: 6px;
    flex-wrap: wrap;
  }

  .ach-thumb-link {
    line-height: 0;
  }

  .ach-thumb {
    width: 160px;
    height: 120px;
    object-fit: cover;
    border-radius: 2px;
    transition: opacity 0.15s;
  }

  .ach-thumb:hover {
    opacity: 0.8;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .contact-links a {
    font-size: 0.85rem;
    color: var(--text-muted);
    padding: 0.4rem 0.75rem;
    border: 1px solid var(--border);
    border-radius: 3px;
    transition: color 0.15s, border-color 0.15s;
  }

  .contact-links a:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: transparent;
  }
</style>
