---
const { currentPage } = Astro.props;
---

<header>
  <nav>
    <a href="/photo/" class="logo">./jpdias/photo</a>
    <ul>
      <li><a href="/" class={currentPage === 'home-root' ? 'active' : ''}>/jpdias</a></li>
      <li><a href="/photo/" class={currentPage === 'home' ? 'active' : ''}>/photos</a></li>
      <li><a href="/photo/globe" class={currentPage === 'globe' ? 'active' : ''}>/globe</a></li>
      <li><a href="/photo/about" class={currentPage === 'about' ? 'active' : ''}>/about</a></li>
    </ul>
  </nav>
</header>
<hr class="nav-hr" />

<style>
  header {
    padding: 1.5rem 1.5rem 0;
  }

  nav {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  a {
    text-decoration: none;
  }

  .logo {
    font-family: 'Lato', sans-serif;
    font-weight: 300;
    font-size: 1.3rem;
    color: var(--text);
    letter-spacing: -0.01em;
  }

  .logo:hover {
    background: transparent;
    color: var(--accent);
  }

  ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  ul a {
    color: var(--text-muted);
    padding: 0.25rem 0.5rem;
    font-size: 0.85rem;
    border-radius: 3px;
    text-decoration: none;
  }

  ul a.active,
  ul a:hover {
    color: var(--accent);
    background: transparent;
  }

  .nav-hr {
    border: 0;
    margin: 0.75rem auto 0;
    max-width: 1100px;
    height: 2px;
    background: var(--accent);
    opacity: 0.2;
  }
</style>
