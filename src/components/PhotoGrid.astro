---
import type { Photo } from '../types';
import { imageUrl } from '../utils/images';

export interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

const categories = [...new Set(photos.map(p => p.category))].sort();

const tagCounts = new Map<string, number>();
for (const p of photos) for (const t of p.tags) tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
const topTags = [...tagCounts.entries()].sort(([a], [b]) => Number(a) - Number(b)).slice(0, 20).map(([t]) => t);
---

<div class="container">
  <div class="location-filter" id="location-filter" style="display:none">
    <span></span>
    <a href="/photo/" class="clear-filter">clear</a>
  </div>
  <div class="controls">
    <div class="categories">
      <button class="chip active" data-filter="all">*</button>
      {categories.map(cat => (
        <button class="chip" data-filter={cat}>{cat}</button>
      ))}
    </div>
    {topTags.length > 0 && (
      <div class="tags">
        {topTags.map(tag => (
          <button class="tag-chip" data-tag={tag}>#{tag}</button>
        ))}
      </div>
    )}
  </div>

  <div class="grid" id="photo-grid">
    {photos.map((photo, i) => (
      <div
        class="grid-item"
        data-category={photo.category}
        data-tags={photo.tags.join(',')}
        data-location={photo.country ?? ''}
        data-fullsize={imageUrl(photo.fullsize)}
        data-title={photo.title}
        data-desc={photo.description}
        data-location-name={photo.location?.name ?? ''}
        data-country={photo.country ?? ''}
        data-date={photo.date}
        data-camera={photo.camera}
        data-slug={photo.slug}
        data-lat={photo.location?.lat ?? ''}
        data-lng={photo.location?.lng ?? ''}
        data-iso={photo.iso ?? ''}
        data-aperture={photo.aperture ?? ''}
        data-focal={photo.focalLength ?? ''}
        data-shutter={photo.shutterSpeed ?? ''}
        data-index={i}
        style={`--i: ${i}`}
      >
        <img
          data-src={imageUrl(photo.thumbnail)}
          alt={photo.title}
          width={photo.width}
          height={photo.height}
        />
        <div class="overlay">
          <span class="overlay-title">{photo.title}</span>
          {photo.location && <span class="overlay-location">{photo.location.name}</span>}
        </div>
      </div>
    ))}
  </div>
</div>

<div class="modal" id="photo-modal">
  <div class="modal-backdrop" id="modal-backdrop"></div>

  <div class="modal-content">
    <div class="modal-body">
      <!-- The image wrap holds only the photo (so nothing sits on top of
           it); arrows and the info toggle live in a plain bar underneath,
           in their own dedicated space. -->
      <div class="modal-visual">
        <div class="modal-image-wrap" id="modal-image-wrap">
          <img class="modal-image" id="modal-image" src="" alt="" />
        </div>
        <div class="modal-controls">
          <button class="modal-arrow modal-prev" id="modal-prev" title="Previous (←)">‹</button>
          <button class="modal-info-toggle" id="modal-info-toggle" title="Toggle details" aria-label="Toggle details">ⓘ</button>
          <button class="modal-arrow modal-next" id="modal-next" title="Next (→)">›</button>
        </div>
      </div>
      <div class="modal-info" id="modal-info">
        <div class="modal-header">
          <h2 class="modal-title" id="modal-title"></h2>
          <span class="modal-counter" id="modal-counter"></span>
          <button class="modal-share" id="modal-share" title="Copy link">⎘</button>
          <button class="modal-close" id="modal-close" title="Close (Esc)">✕</button>
        </div>
        <div class="modal-meta">
          <div class="modal-details" id="modal-details"></div>
          <div class="modal-tech-wrap" id="modal-tech-wrap" style="display:none">
            <div class="tech-rows" id="modal-tech"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function detailRow(label: string, val: string) {
    return `<div class="detail-row"><span class="detail-label">${label}</span><span class="detail-value">${val}</span></div>`;
  }

  function renderTech(el: HTMLElement) {
    const rows: string[] = [];

    const addRow = (label: string, val: string) => {
      if (!val) return;
      rows.push(detailRow(label, val));
    };

    addRow('iso', el.dataset.iso ? `ISO ${el.dataset.iso}` : '');
    addRow('aperture', el.dataset.aperture ?? '');
    addRow('focal length', el.dataset.focal ?? '');
    addRow('shutter', el.dataset.shutter ?? '');

    const tech = document.getElementById('modal-tech')!;
    tech.innerHTML = rows.join('');
  }

  const chips = document.querySelectorAll('.chip');
  const tagChips = document.querySelectorAll('.tag-chip');
  const items = document.querySelectorAll<HTMLElement>('.grid-item');

  let activeCategory = 'all';
  let activeTag: string | null = null;
  let activeLocation: string | null = null;

  const urlParams = new URLSearchParams(window.location.search);
  const locationParam = urlParams.get('location');

  if (locationParam) {
    activeLocation = locationParam;
    const banner = document.getElementById('location-filter');
    if (banner) {
      banner.style.display = 'flex';
      banner.querySelector('span')!.textContent = `filtered by ${locationParam}`;
    }
  }

  function getVisibleItems(): HTMLElement[] {
    return [...items].filter(item => !item.classList.contains('hidden'));
  }

  function filter() {
    items.forEach(item => {
      const cat = item.dataset.category;
      const tags = (item.dataset.tags ?? '').split(',');
      const loc = item.dataset.location;
      const matchCat = activeCategory === 'all' || cat === activeCategory;
      const matchTag = !activeTag || tags.includes(activeTag);
      const matchLoc = !activeLocation || loc === activeLocation;
      item.classList.toggle('hidden', !(matchCat && matchTag && matchLoc));
    });
  }

  chips.forEach(btn => {
    btn.addEventListener('click', () => {
      chips.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCategory = btn.dataset.filter!;
      filter();
    });
  });

  tagChips.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      if (activeTag === tag) {
        activeTag = null;
        tagChips.forEach(b => b.classList.remove('active'));
      } else {
        activeTag = tag;
        tagChips.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      }
      filter();
    });
  });

  filter();

  const modal = document.getElementById('photo-modal')!;
  const modalImage = document.getElementById('modal-image') as HTMLImageElement;
  const modalImageWrap = document.getElementById('modal-image-wrap') as HTMLElement;
  const modalTitle = document.getElementById('modal-title')!;
  const modalCounter = document.getElementById('modal-counter')!;
  const modalDetails = document.getElementById('modal-details')!;
  const modalInfoToggle = document.getElementById('modal-info-toggle')!;
  let currentIndex = -1;
  let closeTimer: ReturnType<typeof setTimeout> | null = null;

  function openModal(el: HTMLElement) {
    const visible = getVisibleItems();
    currentIndex = visible.indexOf(el);
    renderModal();
    if (closeTimer) clearTimeout(closeTimer);
    modal.classList.remove('info-open');
    modal.classList.add('open');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => requestAnimationFrame(() => modal.classList.add('show')));
    const slug = el.dataset.slug;
    if (slug) history.replaceState(null, '', `#${slug}`);
  }

  function closeModal() {
    modal.classList.remove('show');
    document.body.style.overflow = '';
    currentIndex = -1;
    closeTimer = setTimeout(() => modal.classList.remove('open'), 220);
    history.replaceState(null, '', window.location.pathname + window.location.search);
  }

  function renderModal() {
    const visible = getVisibleItems();
    if (currentIndex < 0 || currentIndex >= visible.length) return closeModal();
    const el = visible[currentIndex];
    modalImage.src = el.dataset.fullsize!;
    modalImage.alt = el.dataset.title!;
    modalTitle.textContent = el.dataset.title!;
    modalCounter.textContent = `${currentIndex + 1} / ${visible.length}`;

    const slug = el.dataset.slug;
    if (slug) history.replaceState(null, '', `#${slug}`);

    const rows: string[] = [];
    if (el.dataset.locationName) rows.push(detailRow('location', el.dataset.locationName));
    if (el.dataset.country) rows.push(detailRow('country', el.dataset.country));
    if (el.dataset.date) rows.push(detailRow('date', el.dataset.date));
    if (el.dataset.camera) rows.push(detailRow('camera', el.dataset.camera));
    modalDetails.innerHTML = rows.join('');

    const techWrap = document.getElementById('modal-tech-wrap')!;
    const hasTech = el.dataset.iso || el.dataset.aperture || el.dataset.focal || el.dataset.shutter;
    if (hasTech) {
      techWrap.style.display = 'block';
      renderTech(el);
    } else {
      techWrap.style.display = 'none';
    }

    (document.getElementById('modal-prev') as HTMLButtonElement).disabled = currentIndex <= 0;
    (document.getElementById('modal-next') as HTMLButtonElement).disabled = currentIndex >= visible.length - 1;
  }

  function navigate(dir: number) {
    const visible = getVisibleItems();
    const next = currentIndex + dir;
    if (next >= 0 && next < visible.length) {
      currentIndex = next;
      renderModal();
    }
  }

  items.forEach(item => {
    item.addEventListener('click', () => openModal(item));
  });

  document.getElementById('modal-backdrop')!.addEventListener('click', closeModal);
  document.getElementById('modal-close')!.addEventListener('click', closeModal);
  document.getElementById('modal-share')!.addEventListener('click', () => {
    const visible = getVisibleItems();
    const el = visible[currentIndex];
    const slug = el?.dataset.slug;
    const url = `${window.location.origin}${window.location.pathname.replace(/\/$/, '')}/photos/${slug}`;
    navigator.clipboard.writeText(url).then(() => {
      const btn = document.getElementById('modal-share')!;
      btn.textContent = '✓';
      setTimeout(() => { btn.textContent = '⎘'; }, 1200);
    });
  });
  document.getElementById('modal-prev')!.addEventListener('click', () => navigate(-1));
  document.getElementById('modal-next')!.addEventListener('click', () => navigate(1));

  // Landscape-mobile "info" panel toggle. The button only shows in that
  // layout (see CSS); harmless elsewhere.
  modalInfoToggle.addEventListener('click', () => {
    modal.classList.toggle('info-open');
  });

  document.addEventListener('keydown', (e) => {
    if (!modal.classList.contains('open')) return;
    if (e.key === 'Escape') closeModal();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });

  // Swipe to move between photos. Tracked on the image wrap so it never
  // fights with scrolling inside the details panel.
  let touchStartX = 0;
  let touchStartY = 0;
  let touchDeltaX = 0;
  let isSwiping = false;

  modalImageWrap.addEventListener('touchstart', (e) => {
    if (e.touches.length !== 1) return;
    touchStartX = e.touches[0].clientX;
    touchStartY = e.touches[0].clientY;
    touchDeltaX = 0;
    isSwiping = true;
    modalImage.style.transition = 'none';
  }, { passive: true });

  modalImageWrap.addEventListener('touchmove', (e) => {
    if (!isSwiping) return;
    const dx = e.touches[0].clientX - touchStartX;
    const dy = e.touches[0].clientY - touchStartY;
    if (Math.abs(dx) > Math.abs(dy)) {
      touchDeltaX = dx;
      modalImage.style.transform = `translateX(${dx}px)`;
    }
  }, { passive: true });

  const endSwipe = () => {
    if (!isSwiping) return;
    isSwiping = false;
    modalImage.style.transition = '';
    modalImage.style.transform = '';
    const threshold = 60;
    if (touchDeltaX <= -threshold) navigate(1);
    else if (touchDeltaX >= threshold) navigate(-1);
    touchDeltaX = 0;
  };

  modalImageWrap.addEventListener('touchend', endSwipe);
  modalImageWrap.addEventListener('touchcancel', endSwipe);

  // Lazy load images via IntersectionObserver
  const lazyObserver = new IntersectionObserver((entries) => {
    for (const entry of entries) {
      if (!entry.isIntersecting) continue;
      const img = entry.target.querySelector<HTMLImageElement>('img');
      if (img && img.dataset.src && !img.src) {
        img.src = img.dataset.src;
        img.removeAttribute('data-src');
      }
      lazyObserver.unobserve(entry.target);
    }
  }, { rootMargin: '300px' });

  const origFilter = filter;
  filter = function () {
    origFilter();
    items.forEach(item => {
      if (!item.classList.contains('hidden')) lazyObserver.observe(item);
    });
  };

  filter();

  const hash = window.location.hash.replace('#', '');
  if (hash) {
    const target = [...items].find(i => i.dataset.slug === hash);
    if (target) openModal(target);
  }
</script>

<style>
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .controls {
    margin-bottom: 1.5rem;
  }

  .location-filter {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
    padding: 0.5rem 0.75rem;
    background: rgba(254, 92, 53, 0.08);
    border: 1px solid rgba(254, 92, 53, 0.2);
    border-radius: 4px;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .clear-filter {
    font-size: 0.75rem;
    color: var(--accent);
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .clear-filter:hover {
    opacity: 1;
    background: transparent;
  }

  .categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25rem;
    margin-bottom: 0.5rem;
  }

  .chip {
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 0.15rem 0.5rem;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    cursor: pointer;
    transition: color 0.15s;
    border-radius: 3px;
  }

  .chip:hover,
  .chip.active {
    color: var(--accent);
    background: transparent;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.15rem;
  }

  .tag-chip {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.25);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.75rem;
    cursor: pointer;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    transition: color 0.15s;
  }

  .tag-chip:hover,
  .tag-chip.active {
    color: var(--accent);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 0.5rem;
  }

  .grid-item {
    position: relative;
    text-decoration: none;
    color: inherit;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: var(--bg-card);
    transition: opacity 0.15s;
    cursor: pointer;
  }

  .grid-item.hidden {
    display: none;
  }

  .grid-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #2a2a2a;
    transition: scale 0.4s ease;
    filter: saturate(0.9);
  }

  .grid-item:hover img {
    scale: 1.03;
    filter: saturate(1);
  }

  .overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 1.5rem 1rem 0.75rem;
    background: linear-gradient(transparent 50%, rgba(0, 0, 0, 0.6));
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .grid-item:hover .overlay {
    opacity: 1;
  }

  .overlay-title {
    font-size: 0.8rem;
    font-weight: 500;
    color: #fff;
  }

  .overlay-location {
    font-size: 0.7rem;
    color: var(--accent);
    margin-top: 0.1rem;
  }

  /* Modal: hidden by default via display, faded/scaled in via .show */
  .modal {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.22s ease;
  }

  .modal.open {
    display: flex;
  }

  .modal.show {
    opacity: 1;
  }

  .modal-backdrop {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, rgba(20, 20, 20, 0.97) 0%, rgba(0, 0, 0, 0.98) 100%);
  }

  .modal-content {
    position: relative;
    width: 90vw;
    max-width: 130vh;
    max-height: 95vh;
    display: flex;
    flex-direction: column;
    transform: scale(0.96) translateY(6px);
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.3, 1);
  }

  .modal.show .modal-content {
    transform: scale(1) translateY(0);
  }

  .modal-body {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    overflow-y: auto;
    min-height: 0;
  }

  .modal-visual {
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  .modal-image-wrap {
    border-radius: 4px;
    overflow: hidden;
    flex-shrink: 1;
    min-height: 0;
    touch-action: pan-y;
  }

  .modal-image {
    width: 100%;
    max-height: 70vh;
    object-fit: contain;
    display: block;
    user-select: none;
    -webkit-user-drag: none;
  }

  /* ---------- controls: a plain bar under the photo, nothing on it ---------- */
  .modal-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    padding: 0.35rem 0.25rem 0;
  }

  .modal-arrow {
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.45);
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.25rem 0.75rem;
    border-radius: 3px;
    transition: color 0.15s;
  }

  .modal-arrow:hover:not(:disabled) {
    color: var(--accent);
  }

  .modal-arrow:disabled {
    opacity: 0.15;
    cursor: default;
  }

  /* Info toggle: only meaningful once the info panel becomes an overlay
     (landscape mobile below), hidden everywhere else. */
  .modal-info-toggle {
    display: none;
    background: none;
    border: none;
    color: rgba(255, 255, 255, 0.45);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    transition: color 0.15s;
  }

  .modal-info-toggle:hover {
    color: var(--accent);
  }

  .modal-info {
    padding: 0 0.25rem;
  }

  .modal-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }

  .modal-title {
    font-size: 1.1rem;
    font-weight: 300;
    font-family: 'Lato', sans-serif;
    color: var(--text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .modal-counter {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: 'IBM Plex Mono', monospace;
    flex-shrink: 0;
  }

  .modal-close {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 1.1rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  .modal-close:hover {
    color: var(--accent);
  }

  .modal-share {
    background: none;
    border: none;
    color: var(--text-muted);
    font-size: 0.95rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    border-radius: 3px;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  .modal-share:hover {
    color: var(--accent);
  }

  .modal-close:focus-visible,
  .modal-share:focus-visible,
  .modal-info-toggle:focus-visible,
  .modal-arrow:focus-visible,
  .chip:focus-visible,
  .tag-chip:focus-visible {
    outline: 1px solid var(--accent);
    outline-offset: 2px;
  }

  .modal-meta {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
  }

  .modal-details {
    width: 50%;
  }

  .modal-tech-wrap {
    flex-shrink: 0;
    width: 50%;
    margin-left: auto;
  }

  /* ---------- detail rows: fixed label column + dotted "tab" leader + value ---------- */
  .modal-details :global(.detail-row),
  .modal-tech-wrap :global(.detail-row) {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: var(--text);
    margin-bottom: 0.35rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .modal-details :global(.detail-row:last-child),
  .modal-tech-wrap :global(.detail-row:last-child) {
    border-bottom: none;
  }

  .modal-details :global(.detail-label),
  .modal-tech-wrap :global(.detail-label) {
    flex: 0 0 auto;
    color: var(--text-muted);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .modal-details :global(.detail-value),
  .modal-tech-wrap :global(.detail-value) {
    flex: 0 0 auto;
    text-align: right;
    white-space: nowrap;
  }

  /* ================= Mobile: portrait ================= */
  @media (max-width: 640px) {
    .modal-content {
      width: 100vw;
      max-width: none;
      height: 100%;
      max-height: 100%;
    }

    .modal-body {
      padding: 0 0.75rem env(safe-area-inset-bottom, 0.75rem);
    }

    .modal-image {
      max-height: 55vh;
    }

    .modal-meta {
      flex-direction: column;
    }

    .modal-details,
    .modal-tech-wrap {
      width: 100%;
    }

    .modal-tech-wrap {
      margin-left: 0;
    }

    .modal-title {
      font-size: 1rem;
    }
  }

  /* ================= Mobile: landscape =================
     Short viewports (phones on their side) get almost no vertical room,
     so the photo takes the full frame and details slide in on demand
     instead of pushing the image down. */
  @media (max-width: 900px) and (orientation: landscape) {
    .modal-content {
      width: 100vw;
      max-width: none;
      height: 100%;
      max-height: 100%;
    }

    .modal-body {
      flex-direction: row;
      height: 100%;
      gap: 0;
      overflow: hidden;
    }

    .modal-visual {
      flex: 1;
      height: 100%;
      min-height: 0;
    }

    .modal-image-wrap {
      flex: 1;
      min-height: 0;
      border-radius: 0;
    }

    .modal-image {
      max-height: 100%;
      height: 100%;
    }

    .modal-controls {
      padding: 0.35rem 0.5rem;
    }

    .modal-info-toggle {
      display: block;
    }

    .modal-info {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(78vw, 320px);
