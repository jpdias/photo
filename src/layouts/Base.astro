---
export interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
}

const { description, image, url } = Astro.props;
const siteUrl = 'https://jpdias.github.io/photo';
const ogImage = image ? (image.startsWith('http') ? image : `${siteUrl}${image}`) : '';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="theme-color" content="#202020" />
    <title>./jpdias/photo</title>
    <meta name="description" content={description ?? "jpdias photo portfolio"} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={`./jpdias/photo`} />
    <meta property="og:description" content={description ?? "jpdias photo portfolio"} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {url && <meta property="og:url" content={`${siteUrl}${url}`} />}
    <meta property="og:site_name" content="./jpdias/photo" />
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={`./jpdias/photo`} />
    <meta name="twitter:description" content={description ?? "jpdias photo portfolio"} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@300;400;500;600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      :root {
        --accent: #fe5c35;
        --accent-hover: #ff7a4a;
        --bg: #202020;
        --bg-card: rgba(255, 255, 255, 0.04);
        --text: rgba(255, 255, 255, 0.8);
        --text-muted: rgba(255, 255, 255, 0.45);
        --border: rgba(255, 255, 255, 0.08);
      }

      html {
        scrollbar-color: var(--accent) var(--bg);
        scrollbar-width: thin;
      }

      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg);
      }
      ::-webkit-scrollbar-thumb {
        background: var(--accent);
      }

      body {
        font-family: 'IBM Plex Mono', 'Anonymous Pro', monospace;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
        font-size: 0.9rem;
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
      }

      ::selection {
        background: var(--accent);
        color: var(--bg);
      }

      a {
        color: var(--accent);
        text-decoration: none;
        transition: background 0.15s, color 0.15s;
      }

      a:hover {
        background: var(--accent);
        color: var(--bg);
        border-radius: 3px;
      }

      h1, h2, h3, h4 {
        font-family: 'Lato', sans-serif;
        font-weight: 300;
      }

      footer {
        height: 6rem;
      }

      @media (max-width: 768px) {
        body {
          font-size: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <slot />
    <footer></footer>
  </body>
</html>
